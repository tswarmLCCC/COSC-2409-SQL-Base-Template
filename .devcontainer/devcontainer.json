{
  "name": "Postgres Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [5432],
  "remoteEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@db:5432/mydb"
  },
  "features": {
    "ghcr.io/robbert229/devcontainer-features/postgresql-client:1": {}
  }
}